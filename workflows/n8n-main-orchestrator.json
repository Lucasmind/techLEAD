{
  "name": "Tech LEAD - Main Orchestrator",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "minutes",
              "minutesInterval": 30
            }
          ]
        }
      },
      "id": "cron-trigger",
      "name": "30 Minute Cycle",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.1,
      "position": [250, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.NOCODB_API_URL }}/api/v1/db/data/nc/projects_table",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "where",
              "value": "(status,eq,active)"
            }
          ]
        },
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "xc-auth",
              "value": "={{ $credentials.nocodb.apiKey }}"
            }
          ]
        },
        "options": {}
      },
      "id": "fetch-projects",
      "name": "Fetch Active Projects",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [450, 300]
    },
    {
      "parameters": {
        "url": "=https://api.github.com/repos/{{ $json.repository_url.split('/')[3] }}/{{ $json.repository_url.split('/')[4] }}/issues",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "state",
              "value": "open"
            },
            {
              "name": "per_page",
              "value": "100"
            }
          ]
        },
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $credentials.github.token }}"
            },
            {
              "name": "Accept",
              "value": "application/vnd.github+json"
            }
          ]
        }
      },
      "id": "fetch-issues",
      "name": "Fetch GitHub Issues",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [650, 300]
    },
    {
      "parameters": {
        "command": "=echo '{{ JSON.stringify($json) }}' | claude --format json --prompt \"You are Tech LEAD, an intelligent orchestrator for GitHub development. Analyze these open issues and select the most appropriate one to work on next. Consider priority, complexity, dependencies, and project goals. Return JSON with: {selected_issue: number, reasoning: string, estimated_hours: number}\""
      },
      "id": "claude-decision",
      "name": "Claude Decision - Select Issue",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [850, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.NOCODB_API_URL }}/api/v1/db/data/nc/decisions_log",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"project_id\": \"{{ $node['fetch-projects'].json.id }}\",\n  \"decision_type\": \"issue_selection\",\n  \"claude_input\": {{ JSON.stringify($node['fetch-issues'].json) }},\n  \"claude_output\": {{ JSON.stringify($json) }},\n  \"execution_status\": \"pending\"\n}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "xc-auth",
              "value": "={{ $credentials.nocodb.apiKey }}"
            }
          ]
        }
      },
      "id": "log-decision",
      "name": "Log Decision to NocoDB",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [1050, 300]
    },
    {
      "parameters": {
        "resource": "message",
        "operation": "sendMessage",
        "chatId": "={{ $node['fetch-projects'].json.telegram_chat_id }}",
        "text": "=🤖 Tech LEAD Decision:\\n\\nSelected Issue: #{{ $json.selected_issue }}\\nReasoning: {{ $json.reasoning }}\\nEstimated Hours: {{ $json.estimated_hours }}\\n\\nApprove this selection?\\n/approve or /reject",
        "additionalFields": {
          "replyMarkup": {
            "inlineKeyboard": {
              "keyboard": [
                [
                  {
                    "text": "✅ Approve",
                    "callbackData": "=approve_{{ $json.selected_issue }}"
                  },
                  {
                    "text": "❌ Reject",
                    "callbackData": "=reject_{{ $json.selected_issue }}"
                  }
                ]
              ]
            }
          }
        }
      },
      "id": "telegram-approval",
      "name": "Telegram - PM Approval",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.1,
      "position": [1250, 300],
      "credentials": {
        "telegramApi": {
          "id": "telegram-bot-credentials",
          "name": "Tech LEAD Telegram Bot"
        }
      }
    },
    {
      "parameters": {
        "mode": "wait",
        "webhookPath": "tech-lead-approval",
        "options": {
          "responseData": "firstEntryJson"
        }
      },
      "id": "wait-for-approval",
      "name": "Wait for PM Approval",
      "type": "n8n-nodes-base.wait",
      "typeVersion": 1,
      "position": [1450, 300],
      "webhookId": "approval-webhook"
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{ $json.approved }}",
              "value2": true
            }
          ]
        }
      },
      "id": "check-approval",
      "name": "Check Approval",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [1650, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://api.github.com/repos/{{ $node['fetch-projects'].json.repository_url.split('/')[3] }}/{{ $node['fetch-projects'].json.repository_url.split('/')[4] }}/actions/workflows/claude.yml/dispatches",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $credentials.github.token }}"
            },
            {
              "name": "Accept",
              "value": "application/vnd.github+json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"ref\": \"main\",\n  \"inputs\": {\n    \"issue_number\": \"{{ $node['claude-decision'].json.selected_issue }}\",\n    \"instructions\": \"Implement this issue following best practices\"\n  }\n}"
      },
      "id": "trigger-claude",
      "name": "Trigger @claude Workflow",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [1850, 250]
    },
    {
      "parameters": {
        "resource": "message",
        "operation": "sendMessage",
        "chatId": "={{ $node['fetch-projects'].json.telegram_chat_id }}",
        "text": "❌ Selection rejected. Will retry in next cycle."
      },
      "id": "rejection-message",
      "name": "Send Rejection Message",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.1,
      "position": [1850, 350],
      "credentials": {
        "telegramApi": {
          "id": "telegram-bot-credentials",
          "name": "Tech LEAD Telegram Bot"
        }
      }
    }
  ],
  "connections": {
    "30 Minute Cycle": {
      "main": [
        [
          {
            "node": "Fetch Active Projects",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Fetch Active Projects": {
      "main": [
        [
          {
            "node": "Fetch GitHub Issues",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Fetch GitHub Issues": {
      "main": [
        [
          {
            "node": "Claude Decision - Select Issue",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Claude Decision - Select Issue": {
      "main": [
        [
          {
            "node": "Log Decision to NocoDB",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Log Decision to NocoDB": {
      "main": [
        [
          {
            "node": "Telegram - PM Approval",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Telegram - PM Approval": {
      "main": [
        [
          {
            "node": "Wait for PM Approval",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Wait for PM Approval": {
      "main": [
        [
          {
            "node": "Check Approval",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Check Approval": {
      "main": [
        [
          {
            "node": "Trigger @claude Workflow",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "Send Rejection Message",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "active": false,
  "settings": {
    "executionOrder": "v1"
  },
  "versionId": "01",
  "id": "tech-lead-main-orchestrator",
  "meta": {
    "instanceId": "tech-lead-instance"
  },
  "tags": []
}