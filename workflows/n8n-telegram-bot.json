{
  "name": "Tech LEAD - Telegram Bot Handler",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "telegram-webhook",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "webhook-trigger",
      "name": "Telegram Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1.1,
      "position": [250, 300],
      "webhookId": "telegram-bot-webhook"
    },
    {
      "parameters": {
        "jsCode": "// Parse Telegram message\nconst update = $input.first().json;\nlet messageType = 'unknown';\nlet chatId = null;\nlet text = '';\nlet callbackData = '';\nlet userId = null;\n\nif (update.message) {\n  messageType = 'message';\n  chatId = update.message.chat.id;\n  text = update.message.text || '';\n  userId = update.message.from.id;\n} else if (update.callback_query) {\n  messageType = 'callback';\n  chatId = update.callback_query.message.chat.id;\n  callbackData = update.callback_query.data;\n  userId = update.callback_query.from.id;\n  \n  // Answer callback query to remove loading state\n  $('Telegram').answerCallbackQuery(update.callback_query.id);\n}\n\nreturn {\n  messageType,\n  chatId,\n  text,\n  callbackData,\n  userId,\n  original: update\n};"
      },
      "id": "parse-message",
      "name": "Parse Telegram Message",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [450, 300]
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{ $json.messageType }}",
              "operation": "equals",
              "value2": "message"
            }
          ]
        }
      },
      "id": "is-message",
      "name": "Is Message?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [650, 300]
    },
    {
      "parameters": {
        "value": "={{ $json.text }}",
        "rules": {
          "rules": [
            {
              "value": "^/status",
              "output": 0
            },
            {
              "value": "^/pause",
              "output": 1
            },
            {
              "value": "^/resume",
              "output": 2
            },
            {
              "value": "^/projects",
              "output": 3
            },
            {
              "value": "^/help",
              "output": 4
            }
          ]
        },
        "fallbackOutput": 5
      },
      "id": "command-router",
      "name": "Route Commands",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 2,
      "position": [850, 250]
    },
    {
      "parameters": {
        "value": "={{ $json.callbackData }}",
        "rules": {
          "rules": [
            {
              "value": "^approve_",
              "output": 0
            },
            {
              "value": "^reject_",
              "output": 1
            },
            {
              "value": "^merge_pr_",
              "output": 2
            },
            {
              "value": "^changes_pr_",
              "output": 3
            }
          ]
        },
        "fallbackOutput": 4
      },
      "id": "callback-router",
      "name": "Route Callbacks",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 2,
      "position": [850, 450]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ $env.NOCODB_API_URL }}/api/v1/db/data/nc/work_log",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "limit",
              "value": "5"
            },
            {
              "name": "sort",
              "value": "-started_at"
            }
          ]
        },
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "xc-auth",
              "value": "={{ $credentials.nocodb.apiKey }}"
            }
          ]
        }
      },
      "id": "get-status",
      "name": "Get Current Status",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1150, 100]
    },
    {
      "parameters": {
        "resource": "message",
        "operation": "sendMessage",
        "chatId": "={{ $node['parse-message'].json.chatId }}",
        "text": "=📊 Tech LEAD Status\\n\\n{{ $json.list.length > 0 ? 'Recent Work:' : 'No active work' }}\\n{{ $json.list.map(w => `• Issue #${w.issue_number} - ${w.status} (${w.github_workflow || 'pending'})`).join('\\n') }}"
      },
      "id": "send-status",
      "name": "Send Status",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.1,
      "position": [1350, 100],
      "credentials": {
        "telegramApi": {
          "id": "telegram-bot-credentials",
          "name": "Tech LEAD Telegram Bot"
        }
      }
    },
    {
      "parameters": {
        "method": "PATCH",
        "url": "={{ $env.NOCODB_API_URL }}/api/v1/db/data/nc/projects_table",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "where",
              "value": "=(telegram_chat_id,eq,{{ $node['parse-message'].json.chatId }})"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\"status\": \"paused\"}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "xc-auth",
              "value": "={{ $credentials.nocodb.apiKey }}"
            }
          ]
        }
      },
      "id": "pause-project",
      "name": "Pause Project",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1150, 200]
    },
    {
      "parameters": {
        "resource": "message",
        "operation": "sendMessage",
        "chatId": "={{ $node['parse-message'].json.chatId }}",
        "text": "⏸️ Tech LEAD paused. Use /resume to continue."
      },
      "id": "confirm-pause",
      "name": "Confirm Pause",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.1,
      "position": [1350, 200],
      "credentials": {
        "telegramApi": {
          "id": "telegram-bot-credentials",
          "name": "Tech LEAD Telegram Bot"
        }
      }
    },
    {
      "parameters": {
        "method": "PATCH",
        "url": "={{ $env.NOCODB_API_URL }}/api/v1/db/data/nc/projects_table",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "where",
              "value": "=(telegram_chat_id,eq,{{ $node['parse-message'].json.chatId }})"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\"status\": \"active\"}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "xc-auth",
              "value": "={{ $credentials.nocodb.apiKey }}"
            }
          ]
        }
      },
      "id": "resume-project",
      "name": "Resume Project",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1150, 300]
    },
    {
      "parameters": {
        "resource": "message",
        "operation": "sendMessage",
        "chatId": "={{ $node['parse-message'].json.chatId }}",
        "text": "▶️ Tech LEAD resumed. Automation active."
      },
      "id": "confirm-resume",
      "name": "Confirm Resume",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.1,
      "position": [1350, 300],
      "credentials": {
        "telegramApi": {
          "id": "telegram-bot-credentials",
          "name": "Tech LEAD Telegram Bot"
        }
      }
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ $env.NOCODB_API_URL }}/api/v1/db/data/nc/projects_table",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "xc-auth",
              "value": "={{ $credentials.nocodb.apiKey }}"
            }
          ]
        }
      },
      "id": "list-projects",
      "name": "List Projects",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1150, 400]
    },
    {
      "parameters": {
        "resource": "message",
        "operation": "sendMessage",
        "chatId": "={{ $node['parse-message'].json.chatId }}",
        "text": "=📁 Active Projects:\\n\\n{{ $json.list.map(p => `• ${p.project_identifier}\\n  ${p.repository_url}\\n  Status: ${p.status}`).join('\\n\\n') }}"
      },
      "id": "send-projects",
      "name": "Send Projects List",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.1,
      "position": [1350, 400],
      "credentials": {
        "telegramApi": {
          "id": "telegram-bot-credentials",
          "name": "Tech LEAD Telegram Bot"
        }
      }
    },
    {
      "parameters": {
        "resource": "message",
        "operation": "sendMessage",
        "chatId": "={{ $node['parse-message'].json.chatId }}",
        "text": "🤖 Tech LEAD Commands:\\n\\n/status - Current work status\\n/pause - Pause automation\\n/resume - Resume automation\\n/projects - List active projects\\n/help - Show this help\\n\\nOr just ask me anything about the project!"
      },
      "id": "send-help",
      "name": "Send Help",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.1,
      "position": [1350, 500],
      "credentials": {
        "telegramApi": {
          "id": "telegram-bot-credentials",
          "name": "Tech LEAD Telegram Bot"
        }
      }
    },
    {
      "parameters": {
        "command": "=echo '{{ $node['parse-message'].json.text }}' | claude --format text --prompt \"You are Tech LEAD. Answer this question based on your knowledge of the project and development work: {{ $node['parse-message'].json.text }}. Be concise and helpful.\""
      },
      "id": "claude-natural",
      "name": "Claude Natural Language",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [1150, 600]
    },
    {
      "parameters": {
        "resource": "message",
        "operation": "sendMessage",
        "chatId": "={{ $node['parse-message'].json.chatId }}",
        "text": "={{ $json.stdout }}"
      },
      "id": "send-claude-response",
      "name": "Send Claude Response",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.1,
      "position": [1350, 600],
      "credentials": {
        "telegramApi": {
          "id": "telegram-bot-credentials",
          "name": "Tech LEAD Telegram Bot"
        }
      }
    },
    {
      "parameters": {
        "options": {}
      },
      "id": "webhook-response",
      "name": "Webhook Response",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [1550, 350]
    }
  ],
