        "operation": "sendMessage",
        "chatId": "={{ $node['route-commands'].json.chatId }}",
        "text": "⏸️ Tech LEAD paused. Use /resume to continue."
      },
      "id": "confirm-pause",
      "name": "Confirm Pause",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1,
      "position": [1450, 200]
    },
    {
      "parameters": {
