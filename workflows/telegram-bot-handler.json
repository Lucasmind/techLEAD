    },
    {
      "parameters": {
        "resource": "message",
        "operation": "sendMessage",
        "chatId": "={{ $node['route-commands'].json.chatId }}",
        "text": "📁 Active Projects:\n\n{{ $json.map(p => `• ${p.project_identifier}\\n  ${p.repository_url}\\n  Status: ${p.status}`).join('\\n\\n') }}"
      },
      "id": "send-projects",
      "name": "Send Projects List",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1,
      "position": [1450, 400]
    },
    {
      "parameters": {
        "command": "echo '{{ $node['route-commands'].json.text }}' | claude --prompt \"You are Tech LEAD. Answer this question based on your knowledge of the project and development work: {{ $node['route-commands'].json.text }}. Be concise and helpful.\"",
        "outputFormat": "text"
      },
      "id": "claude-natural",
      "name": "Claude Natural Language",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [1250, 500]
    },
    {
      "parameters": {
        "resource": "message",
        "operation": "sendMessage",
        "chatId": "={{ $node['route-commands'].json.chatId }}",
        "text": "{{ $json.output }}"
      },
      "id": "send-claude-response",
      "name": "Send Claude Response",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1,
      "position": [1450, 500]
    },
    {
      "parameters": {
        "resource": "message",
        "operation": "sendMessage",
        "chatId": "={{ $node['route-commands'].json.chatId }}",
        "text": "🤖 Tech LEAD Commands:\n\n/status - Current work status\n/pause - Pause automation\n/resume - Resume automation\n/projects - List active projects\n/help - Show this help\n\nOr just ask me anything about the project!"
      },
      "id": "send-help",
      "name": "Send Help",
