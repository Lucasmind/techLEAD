# GitHub Configuration
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_OWNER=yourusername
GITHUB_REPO=yourrepository

# Telegram Configuration
TELEGRAM_BOT_TOKEN=0000000000:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
TELEGRAM_CHAT_ID=000000000

# NocoDB Configuration
NOCODB_URL=http://localhost:8080
NOCODB_API_TOKEN=nc_xxxxxxxxxxxxxxxxxxxxxxxxx

# n8n Configuration
N8N_WEBHOOK_BASE_URL=https://your-n8n-instance.com

# Project Settings
DEFAULT_PROJECT_NAME=BACKTEST REFACTOR
PROJECT_CHECK_INTERVAL=30
MAX_TEST_ATTEMPTS=5
PR_CHECK_INTERVAL=10

# Claude CLI Path (if not in PATH)
CLAUDE_CLI_PATH=/usr/local/bin/claude