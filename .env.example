# Tech LEAD Environment Configuration
# Copy this file to .env and fill in your actual values

# n8n API Configuration
# Get your API key from n8n UI: Settings -> API -> Create API Key
N8N_API_URL=http://localhost:5678
N8N_API_KEY=your-n8n-api-key-here

# GitHub Configuration
GITHUB_TOKEN=your-github-pat-here
GITHUB_ORG=your-github-org

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_CHAT_ID=your-telegram-chat-id

# NocoDB Configuration
NOCODB_API_URL=http://localhost:8810
NOCODB_API_TOKEN=your-nocodb-api-token-here

# Database Configuration (from docker-compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-postgres-password
POSTGRES_DB=nocodb

# JWT Secret for NocoDB
NC_AUTH_JWT_SECRET=your-secret-jwt-key-here